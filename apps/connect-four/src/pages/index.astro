---
import "#styles";
import Game from "#components/Game";
import BaseLayout from "#layout";

const id = "connect-four";
const title = "Connect Four";
const canonical = `https://games.rman.dev/${id}`;
const description = `Classic Connect Four game. Play on ${canonical}`;
const thumbnail = `/images/${id}.png`;
---

<BaseLayout {title} {description} {canonical} {thumbnail}>
  <Game client:load />
</BaseLayout>
