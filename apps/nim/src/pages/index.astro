---
import "./_styles/game.css";
import Game from "~/components/Game.tsx";
import Layout from "~/layouts/Layout.astro";

const id = "nim";
const title = "NIM Game";
const canonical = `https://games.rman.dev/${id}`;
const description = `Classic NIM game. Play on ${canonical}`;
const thumbnail = `/thumbnails/${id}.png`;
---

<Layout {title} {description} {canonical} {thumbnail}>
  <Game client:load />
</Layout>
