---
import "#styles";
import Game from "#components/Game";
import Layout from "#layout";

const id = "simon-says";
const title = "Simon Says";
const canonical = `https://games.rman.dev/${id}`;
const description = `Classic Simon Says game. Play on ${canonical}`;
const thumbnail = `/images/${id}.png`;
---

<Layout {title} {description} {canonical} {thumbnail}>
  <Game client:load />
</Layout>
